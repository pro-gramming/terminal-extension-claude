{
  "name": "terminal-ai",
  "displayName": "Terminal AI (Cmd+K)",
  "description": "Cmd+K for your VS Code terminal — describe what you want in plain English, get the right shell command instantly via Claude Code.",
  "version": "0.0.1",
  "publisher": "pro-gramming",
  "license": "MIT",
  "homepage": "https://github.com/pro-gramming/terminal-extension-claude#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/pro-gramming/terminal-extension-claude.git"
  },
  "bugs": {
    "url": "https://github.com/pro-gramming/terminal-extension-claude/issues"
  },
  "keywords": ["terminal", "ai", "claude", "shell", "productivity", "cmd+k"],
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": ["Other", "AI"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalAI.invoke",
        "title": "Terminal AI: Generate Command"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+k",
        "mac": "cmd+k",
        "command": "terminalAI.invoke",
        "when": "terminalFocus"
      }
    ],
    "configuration": {
      "title": "Terminal AI",
      "properties": {
        "terminalAI.claudePath": {
          "type": "string",
          "default": "claude",
          "description": "Path to the Claude Code CLI binary. Defaults to 'claude' (must be on PATH)."
        },
        "terminalAI.systemPrompt": {
          "type": "string",
          "default": "",
          "markdownDescription": "Override the system prompt sent to Claude. Leave empty to use the built-in prompt."
        },
        "terminalAI.timeoutSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 120,
          "description": "Maximum seconds to wait for Claude to respond before timing out."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "test:unit": "npm run compile && mocha 'out/test/**/*.test.js'",
    "vscode:prepublish": "npm run lint && npm run compile",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "mocha": "^10.0.0",
    "typescript": "^5.3.0"
  }
}
