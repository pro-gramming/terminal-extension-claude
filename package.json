{
  "name": "terminal-ai",
  "displayName": "Terminal AI (Cmd+K)",
  "description": "Replicate Cursor's Cmd+K experience in the VS Code terminal using Claude Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalAI.invoke",
        "title": "Terminal AI: Generate Command"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+k",
        "mac": "cmd+k",
        "command": "terminalAI.invoke",
        "when": "terminalFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
